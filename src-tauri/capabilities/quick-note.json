{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "quick-note",
  "description": "Capability for the quick-note capture popup",
  "windows": ["quick-note"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME" }
      ]
    }
  ]
}
